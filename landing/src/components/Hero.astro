---

---

<header id="hero">
	<figure class="hero-banner-wrap" aria-hidden="true">
		<img
			src="/ph-banner-v2.png"
			alt=""
			class="hero-banner"
			loading="eager"
			decoding="async"
		/>
	</figure>
	<div class="container hero-content-shell">
		<div class="hero-inner">
			<div class="hero-greeting">
				<span class="wave">👋</span>
				<span class="greeting-text">Hi, I'm</span>
			</div>
			<h1 class="hero-name">Thomas</h1>
			<p class="hero-handle">
				<span class="at">@</span>parsehex
			</p>
			<p class="hero-bio">
				Self-taught web developer since 2010.
				<br />
				I make things that are <em
					>unusual</em
				> -- AI companions, procedural art, fake news sites, and other things that are
				interesting enough to build.
			</p>
			<div class="hero-links">
				<a
					href="https://github.com/parsehex"
					class="hero-link"
					target="_blank"
					rel="noopener noreferrer"
				>
					<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"
						><path
							d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
						></path></svg
					>
					GitHub
				</a>
				<a
					href="https://parsehex.github.io/"
					class="hero-link"
					target="_blank"
					rel="noopener noreferrer"
				>
					Open Source Portfolio
				</a>
				<!-- <a href="https://mespace.parsehex.dev" class="hero-link mespace-link">
					✦ mespace
				</a> -->
			</div>
		</div>
	</div>
</header>

<style>
	header {
		min-height: 0;
		display: block;
		padding: 0 0 4rem;
	}
	#hero .container {
		display: block;
	}
	.hero-content-shell {
		margin-top: clamp(-4.5rem, -8vw, -2.5rem);
		position: relative;
		z-index: 3;
	}
	.hero-inner {
		max-width: 680px;
		padding: clamp(1.25rem, 2vw, 2rem);
		border-radius: var(--radius-lg);
		border: 1px solid var(--border);
		background: linear-gradient(
			160deg,
			rgba(18, 18, 26, 0.9) 0%,
			rgba(10, 10, 15, 0.84) 100%
		);
		backdrop-filter: blur(8px);
		box-shadow: 0 18px 60px rgba(0, 0, 0, 0.35);
	}
	.hero-banner-wrap {
		position: relative;
		width: 100vw;
		max-width: none;
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);
		overflow: hidden;
		margin-bottom: 0;
	}
	.hero-banner-wrap::before {
		content: '';
		position: absolute;
		inset: 0;
		z-index: 1;
		background: linear-gradient(
			to bottom,
			rgba(10, 10, 15, 0.04) 0%,
			rgba(10, 10, 15, 0.22) 72%,
			rgba(10, 10, 15, 0.45) 100%
		);
	}
	.hero-banner-wrap::after {
		content: '';
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: 2;
		height: min(28%, 7rem);
		background: linear-gradient(to bottom, rgba(10, 10, 15, 0), var(--bg-primary));
	}
	.hero-banner {
		display: block;
		width: 100%;
		height: clamp(250px, 34vw, 460px);
		object-fit: cover;
		object-position: center 40%;
		margin: 0;
		border: 0;
		border-radius: 0;
	}
	.hero-greeting {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 0.75rem;
	}
	.wave {
		font-size: 1.8rem;
		display: inline-block;
		animation: wave-anim 2.5s ease-in-out infinite;
		transform-origin: 70% 70%;
	}
	@keyframes wave-anim {
		0%,
		100% {
			transform: rotate(0deg);
		}
		10% {
			transform: rotate(14deg);
		}
		20% {
			transform: rotate(-8deg);
		}
		30% {
			transform: rotate(14deg);
		}
		40% {
			transform: rotate(-4deg);
		}
		50% {
			transform: rotate(10deg);
		}
		60% {
			transform: rotate(0deg);
		}
	}
	.greeting-text {
		font-size: 1.1rem;
		color: var(--text-secondary);
		font-weight: 400;
	}
	.hero-name {
		font-size: 4.5rem;
		font-weight: 700;
		letter-spacing: -0.04em;
		line-height: 1;
		margin-bottom: 0.25rem;
		background: linear-gradient(
			135deg,
			var(--text-primary) 0%,
			var(--accent-light) 100%
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.hero-handle {
		font-family: var(--font-mono);
		font-size: 1.1rem;
		color: var(--text-muted);
		margin-bottom: 1.5rem;
	}
	.at {
		color: var(--accent);
	}
	.hero-bio {
		font-size: 1.1rem;
		line-height: 1.8;
		color: var(--text-secondary);
		margin-bottom: 2rem;
		max-width: 520px;
	}
	.hero-bio em {
		color: var(--highlight);
		font-style: normal;
		font-weight: 500;
	}
	.hero-links {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.hero-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.6rem 1.2rem;
		border-radius: var(--radius-sm);
		border: 1px solid var(--border);
		color: var(--text-secondary);
		font-size: 0.9rem;
		font-weight: 500;
		transition:
			color var(--transition),
			border-color var(--transition),
			background var(--transition);
	}
	.hero-link:hover {
		color: var(--text-primary);
		border-color: var(--border-hover);
		background: var(--bg-card);
	}
	.mespace-link {
		border-color: rgba(99, 102, 241, 0.2);
		color: var(--accent-light);
	}
	.mespace-link:hover {
		border-color: var(--accent);
		background: var(--bg-accent);
		color: var(--accent-light);
	}

	@media (max-width: 768px) {
		header {
			padding: 0 0 3rem;
		}
		.hero-content-shell {
			margin-top: clamp(-2rem, -7vw, -1.1rem);
		}
		.hero-inner {
			padding: 1.1rem;
			border-radius: var(--radius);
		}
		.hero-banner {
			height: clamp(170px, 45vw, 300px);
		}
		.hero-name {
			font-size: 3rem;
		}
		.hero-bio {
			font-size: 1rem;
		}
	}
	@media (max-width: 480px) {
		.hero-name {
			font-size: 2.4rem;
		}
	}
</style>
