---
import incubating from '../data/incubating.json';
---

<section id="incubating">
	<div class="container">
		<span class="section-label">What I'm Building Toward</span>
		<h2 class="section-title">Getting Off the Ground</h2>
		<p class="section-intro">
			Some ideas are already live. Others are still being shaped into something
			real. This is the lane I'm actively trying to push forward.
		</p>

		<div class="incubating-grid">
			{
				incubating.map((item: any) => (
					<article class="card incubating-card" style={`--incubating-accent: ${item.accent}`}>
						<div class="incubating-header">
							<p class="incubating-status">{item.status}</p>
							<p class="incubating-focus">{item.focus}</p>
						</div>

						<h3 class="incubating-name">{item.name}</h3>

						<p class="incubating-description">{item.description}</p>

						{Array.isArray(item.details) && item.details.length > 0 && (
							<ul class="incubating-details">
								{item.details.map((detail: string) => (
									<li>{detail}</li>
								))}
							</ul>
						)}
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.section-intro {
		max-width: 42rem;
		margin: -1.2rem 0 2rem;
		color: var(--text-secondary);
		font-size: 0.98rem;
	}

	.incubating-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.25rem;
	}

	.incubating-card {
		position: relative;
		overflow: hidden;
	}

	.incubating-card::before {
		content: '';
		position: absolute;
		inset: 0 auto 0 0;
		width: 3px;
		background: var(--incubating-accent);
		opacity: 0.9;
	}

	.incubating-header {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 15rem);
		gap: 1rem;
		align-items: start;
		margin-bottom: 0.65rem;
	}

	.incubating-status {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--incubating-accent);
		margin: 0;
	}

	.incubating-name {
		font-size: 1.2rem;
		font-weight: 650;
		letter-spacing: -0.02em;
		margin-bottom: 0.9rem;
	}

	.incubating-focus {
		font-size: 0.88rem;
		line-height: 1.6;
		color: var(--text-muted);
	}

	.incubating-description {
		color: var(--text-secondary);
		white-space: pre-line;
		margin-bottom: 1rem;
	}

	.incubating-details {
		list-style: none;
		display: grid;
		gap: 0.7rem;
	}

	.incubating-details li {
		position: relative;
		padding-left: 1rem;
		color: var(--text-secondary);
		font-size: 0.92rem;
		line-height: 1.65;
		white-space: pre-line;
	}

	.incubating-details li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.7rem;
		width: 0.38rem;
		height: 0.38rem;
		border-radius: 999px;
		background: var(--incubating-accent);
		box-shadow: 0 0 0 4px color-mix(in srgb, var(--incubating-accent) 16%, transparent);
	}

	@media (max-width: 820px) {
		.incubating-grid {
			grid-template-columns: 1fr;
		}

		.incubating-header {
			grid-template-columns: 1fr;
		}
	}
</style>
